# Text-to-SQL Agent — Environment Configuration
# Copy to .env and fill in your values.

# PostgreSQL (required)
DATABASE_URL=PUT_YOUR_LINK

# OpenRouter (required for LLM)
OPENROUTER_API_KEY=PUT_YOUR_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
PINECONE_API_KEY=PUT_YOUR_KEY

# LLM model — Sonnet recommended for SQL accuracy
# claude-3.5-sonnet: best accuracy for complex multi-JOIN queries
# claude-3.5-haiku:  faster, cheaper, good for simple queries
LLM_MODEL=anthropic/claude-3.5-sonnet
